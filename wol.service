[Unit]
Description=WOL Server
After=network.target

[Service]
Type=simple
User=root                
WorkingDirectory=/opt/wol
Environment="MAC_ADDRESS=34:5A:60:AD:C0:85"
Environment="WAKE_CMD=wakeonlan" 
Environment="PORT=3000"
ExecStart=/opt/wol/wol-server
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target